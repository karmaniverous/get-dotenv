{
  "author": "Jason Williscroft",
  "bin": {
    "getdotenv": "./dist/getdotenv.cli.mjs"
  },
  "bugs": {
    "url": "https://github.com/karmaniverous/get-dotenv/issues"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^15.0.0",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.6",
    "globby": "^16",
    "nanoid": "^6.0.0",
    "package-directory": "^8.2.0",
    "radash": "^12.1.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "description": "Process dotenv files in an arbitrary location & optionally populate environment variables.",
  "devDependencies": {
    "@aws-sdk/client-sts": "^3.1086.0",
    "@dotenvx/dotenvx": "^2.7.3",
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^26",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/eslint-plugin": "^1.6.23",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsonc": "^3.3.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-tsdoc": "^0.5.2",
    "fs-extra": "^11.3.6",
    "git-cliff": "^2.13.1",
    "globals": "^17.7.0",
    "jsonc-eslint-parser": "^3.1.0",
    "knip": "^6.26.0",
    "lefthook": "^2.1.10",
    "npm-packlist": "^10.0.3",
    "prettier": "^3.9.5",
    "release-it": "^20.2.1",
    "rimraf": "^6.1.3",
    "rollup": "^4.62.2",
    "rollup-plugin-dts": "^6.4.1",
    "tslib": "^2.8.1",
    "tsx": "^4.23.1",
    "typedoc": "^0.28.20",
    "typedoc-plugin-mdn-links": "^5.1.1",
    "typedoc-plugin-replace-text": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      }
    },
    "./cli": {
      "import": {
        "types": "./dist/cli.d.ts",
        "default": "./dist/cli.mjs"
      }
    },
    "./cliHost": {
      "import": {
        "types": "./dist/cliHost.d.ts",
        "default": "./dist/cliHost.mjs"
      }
    },
    "./plugins": {
      "import": {
        "types": "./dist/plugins.d.ts",
        "default": "./dist/plugins.mjs"
      }
    },
    "./plugins/aws": {
      "import": {
        "types": "./dist/plugins-aws.d.ts",
        "default": "./dist/plugins-aws.mjs"
      }
    },
    "./plugins/batch": {
      "import": {
        "types": "./dist/plugins-batch.d.ts",
        "default": "./dist/plugins-batch.mjs"
      }
    },
    "./plugins/init": {
      "import": {
        "types": "./dist/plugins-init.d.ts",
        "default": "./dist/plugins-init.mjs"
      }
    },
    "./plugins/cmd": {
      "import": {
        "types": "./dist/plugins-cmd.d.ts",
        "default": "./dist/plugins-cmd.mjs"
      }
    },
    "./config": {
      "import": {
        "types": "./dist/config.d.ts",
        "default": "./dist/config.mjs"
      }
    },
    "./env/overlay": {
      "import": {
        "types": "./dist/env-overlay.d.ts",
        "default": "./dist/env-overlay.mjs"
      }
    }
  },
  "files": [
    "dist",
    "getdotenv.config.json",
    "schema",
    "templates"
  ],
  "homepage": "https://github.com/karmaniverous/get-dotenv#readme",
  "keywords": [
    "cli",
    "configuration",
    "developer-tools",
    "development-environment",
    "devops",
    "dotenv-management",
    "environment-variables",
    "json",
    "nodejs",
    "typescript"
  ],
  "license": "BSD-3-Clause",
  "main": "dist/index.mjs",
  "name": "@karmaniverous/get-dotenv",
  "peerDependencies": {
    "@aws-sdk/client-sts": "^3.965.0",
    "esbuild": "*"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/client-sts": {
      "optional": true
    },
    "esbuild": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "release-it": {
    "git": {
      "changelog": "npx git-cliff --latest --strip header",
      "commitMessage": "chore: release v${version}",
      "requireBranch": "main"
    },
    "github": {
      "release": true
    },
    "hooks": {
      "after:init": [
        "npm run lint",
        "npm run test",
        "npm run build",
        "npm run verify:types",
        "npm run verify:package",
        "npm run verify:bundle",
        "npm run verify:tarball"
      ],
      "after:release": [
        "git switch -c release/${version}",
        "git push -u origin release/${version}",
        "git switch ${branchName}"
      ]
    },
    "npm": {
      "publish": true
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/karmaniverous/get-dotenv"
  },
  "scripts": {
    "generate:schema": "tsx tools/generate-schema.js",
    "build": "npm run generate:schema && rimraf dist && rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "cli": "tsx src/cli/getdotenv",
    "cli:dist": "node dist/getdotenv.cli.mjs",
    "changelog": "git-cliff -o CHANGELOG.md",
    "docs": "typedoc",
    "pack:dry": "npm pack --dry-run",
    "knip": "knip",
    "lint": "eslint . eslint.config.ts",
    "lint:fix": "eslint --fix . eslint.config.ts",
    "release": "dotenvx run -f .env.local -- release-it",
    "release:pre": "dotenvx run -f .env.local -- release-it --no-git.requireBranch --github.prerelease --preRelease",
    "test": "vitest run",
    "typecheck": "tsc",
    "verify:types": "node tools/verify-types.js",
    "verify:package": "node tools/verify-package.js",
    "verify:smoke": "node tools/smoke.js",
    "verify:bundle": "node tools/verify-bundle-imports.js",
    "verify:tarball": "node tools/verify-tarball.js"
  },
  "type": "module",
  "types": "dist/index.d.ts",
  "version": "7.0.11"
}
